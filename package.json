{
  "name": "zk-bench",
  "version": "1.0.0",
  "description": "Standalone PLONK proof generation benchmark for Cardano-Midnight ZK Bridge circuits",
  "private": true,
  "type": "module",
  "scripts": {
    "get-address": "node --experimental-specifier-resolution=node --loader ts-node/esm src/get-address.ts",
    "bench": "vitest run --reporter=verbose",
    "bench:watch": "vitest --reporter=verbose",
    "typecheck": "tsc -p tsconfig.json --noEmit",
"fund-wallet": "vitest run --reporter=verbose src/fund-wallet.test.ts",
    "inspect-wallet": "node --experimental-specifier-resolution=node --loader ts-node/esm src/inspect-wallet.ts"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.8.1",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "2.0.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "2.0.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "2.0.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "2.0.1",
    "@midnight-ntwrk/midnight-js-network-id": "2.0.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "2.0.1",
    "@midnight-ntwrk/midnight-js-types": "2.0.1",
    "@midnight-ntwrk/midnight-js-utils": "2.0.1",
    "@midnight-ntwrk/wallet": "5.0.0",
    "@midnight-ntwrk/wallet-api": "5.0.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "long": "^5.2.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "protobufjs": "^7.4.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  },
  "packageManager": "yarn@1.22.22"
  
}
